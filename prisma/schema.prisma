// TestPilot — Multi-tenant Prisma schema
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // In Prisma 7, the connection URL is passed via the adapter in PrismaClient
  // (lib/prisma.ts) for runtime, and via prisma.config.ts for CLI migrations.
}

// ── Organizations (tenants) ───────────────────────────────────────────────────

model Organization {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  licenseKey     String   @unique @default(cuid())
  licenseStatus  String   @default("active") // active | suspended | expired
  maxMembers     Int      @default(5)
  createdAt      DateTime @default(now())
  createdByAdmin String   // email of super admin who provisioned this org

  // Per-org LLM selection (provider/model/baseUrl). API keys live in OrgApiKey.
  // Null → fall back to the app default (DEFAULT_LLM_CONFIG).
  llmProvider String?
  llmModel    String?
  llmBaseUrl  String?

  // Org-scoped app settings: { maxPages?, deepCrawlMaxPages?, autoSelfHeal? }.
  // Stored in the DB (not a disk file) so they survive redeploys.
  settings Json?

  members  OrgMember[]
  apiKeys  OrgApiKey[]
  sessions Session[]
  contexts ContextStore[]
}

// ── Org members ───────────────────────────────────────────────────────────────

model OrgMember {
  id          String   @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  clerkUserId String?  // null until invite is accepted
  email       String
  displayName String?  // set from Clerk profile on first login
  role        String   @default("MEMBER")  // ORG_ADMIN | MEMBER
  status      String   @default("invited") // invited | active | suspended
  invitedAt   DateTime @default(now())
  joinedAt    DateTime?

  @@unique([orgId, email])
  @@index([clerkUserId])
}

// ── Org-level API keys (encrypted at rest) ────────────────────────────────────

model OrgApiKey {
  id          String   @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  keyName     String   // ANTHROPIC_API_KEY | FIGMA_TOKEN | OPENAI_API_KEY
  keyValue    String   // AES-256-GCM encrypted value
  maskedValue String   // e.g. "sk-ant-...a1b2" — safe to show in UI

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([orgId, keyName])
}

// ── Sessions ──────────────────────────────────────────────────────────────────

model Session {
  id              String   @id @default(cuid())
  orgId           String
  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdByUserId String   // clerkUserId of the member who started this session

  // Target site
  url             String
  figmaFileUrl    String?
  figmaFrameMap   Json?    // Record<frameName, url> — user-confirmed frame→page mapping

  // Pipeline state
  status          String   @default("idle")
  figmaChecking   Boolean  @default(false)

  // Crawled page count — denormalised from siteMap so list views (dashboard)
  // can show it without loading the (large) siteMap JSON blob.
  pagesCount      Int      @default(0)

  // Results (JSON blobs — not huge, no logs here)
  siteMap          Json?
  figmaResult      Json?
  testFiles        Json?    // string[] — absolute paths to spec files
  testResult       Json?    // TestResult
  fixResult        Json?    // FixResult
  triageResult     Json?    // TriageResult
  scenarioResult   Json?    // ScenarioResult
  importedProject  Json?    // ImportedProject
  coverageAnalysis Json?    // CoverageAnalysis
  userFlows        Json?    // UserFlow[]
  contextDoc       String?
  contextDocName   String?
  iteration        Int      @default(0)
  error            String?
  maxPages         Int      @default(10)
  headedMode       Boolean  @default(false)
  figmaOnly        Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  files     SessionFile[]
  runs      TestRun[]
  logChunks SessionLogChunk[]
  scenarios Scenario[]
}

// ── Test runs (append-only execution history) ─────────────────────────────────
// One row per execution — NEVER overwritten. Session.testResult keeps the
// latest result for UI compatibility; this table is the durable history that
// powers trends, flaky-test detection, and per-run logs.

model TestRun {
  id         String    @id @default(cuid())
  sessionId  String
  session    Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  trigger    String    // loop | manual | single-file | scenario
  iteration  Int       @default(0)
  targetFile String?   // set when a single file / scenario was run

  status     String    // passed | failed | error | stopped
  startedAt  DateTime  @default(now())
  durationMs Int?

  // Stats as real columns so SQL can aggregate (pass-rate trends, flaky tests)
  total      Int @default(0)
  passed     Int @default(0)
  failed     Int @default(0)
  errors     Int @default(0)

  caseResults Json?    // { "<file> › <test title>": "passed" | "failed" | "skipped" }
  triage      Json?    // TriageResult for this run
  fix         Json?    // FixResult applied after this run
  output      String?  // trimmed tail of the runner output
  videos      Json?    // string[] — relative paths (ephemeral artifact refs)

  @@index([sessionId, startedAt])
}

// ── Scenarios (user-asked checks, remembered per app) ─────────────────────────
// Every "Test a Scenario" request is stored so (a) the session shows its list
// of asked scenarios, and (b) future sessions on the SAME app (org + origin)
// can offer past scenarios for one-click reuse — copying the already-generated
// spec instead of burning tokens regenerating it.

model Scenario {
  id          String   @id @default(cuid())
  orgId       String
  sessionId   String
  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  urlOrigin   String   // e.g. https://www.saucedemo.com
  description String
  /** Workspace-relative spec path, e.g. tests/scenario-login-and-checkout.spec.ts */
  testPath    String?
  /** passed | failed | error — outcome of the latest run of this scenario */
  lastStatus  String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([sessionId, description])
  @@index([orgId, urlOrigin])
  @@index([sessionId])
}

// ── Session files (durable copy of the test suite) ────────────────────────────
// The workspace on disk is ephemeral (wiped on redeploy). These rows are the
// source of truth for the generated test files so the suite survives deploys
// and can be restored onto a fresh disk before running.

model SessionFile {
  id        String   @id @default(cuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  path      String   // path relative to the workspace dir, e.g. "tests/homepage.spec.ts"
  kind      String   @default("generated") // generated | scenario | figma | fixture | sidecar
  content   String   // file contents (text)
  /** Previous version of the content (one step back) — lets users see what
   *  self-heal changed and provides a manual rollback point. */
  previousContent String?
  /** Soft delete: set when the file is removed/reset so restore skips it
   *  (prevents deleted specs from being resurrected onto fresh disks). */
  deletedAt DateTime?
  updatedAt DateTime @updatedAt

  @@unique([sessionId, path])
  @@index([sessionId])
}

// ── Session log chunks ────────────────────────────────────────────────────────
// Logs are an append-only stream read strictly in order — so they are stored
// as CHUNKS (~dozens of lines each) instead of one row per line: ~100× fewer
// rows, and retention becomes "delete old chunks".

model SessionLogChunk {
  id        BigInt   @id @default(autoincrement())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  seq       Int      // per-session sequence number (ordering)
  lineCount Int
  content   Json     // Array<{ ts: number; msg: string; level: string }>

  createdAt DateTime @default(now())

  @@unique([sessionId, seq])
  @@index([sessionId, id]) // cursor-based catch-up: WHERE id > lastSeen
}

// ── Context store (saved credentials per URL, per org) ────────────────────────

model ContextStore {
  id      String   @id @default(cuid())
  orgId   String
  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  urlKey  String   // normalized URL used as lookup key
  url     String   // display URL
  fields  Json     // ContextField[]

  updatedAt DateTime @updatedAt

  @@unique([orgId, urlKey])
}

// ── Test-case use-case descriptions (durable AI output) ───────────────────────
// One short, user-facing use-case sentence per unique test, keyed by a content
// hash so it is generated ONCE ever (reused across sessions, redeploys, and
// instances) instead of re-hitting the LLM. This replaces an in-memory cache:
// it is durable derived data, not throwaway, so it lives in Postgres.

model TestCaseDescription {
  id        String   @id @default(cuid())
  orgId     String

  host      String   // e.g. "saucedemo.com"
  hash      String   // sha256(host + file + semantic signature)
  title     String   // the test title (reference / display fallback)
  useCase   String   // the AI-generated, user-facing use-case sentence
  area      String?  // functional area (Authentication, Cart, Checkout, …)
  featureId String?  // → Feature.id; promotes the loose `area` label to a real feature
  model     String?  // model that produced it (auditing)

  createdAt DateTime @default(now())

  @@unique([orgId, hash])
  @@index([orgId, host])
  @@index([featureId])
}

// ── App profile & features (the "feature-context spine") ──────────────────────
// One profile per app (org + host) holding the human/business understanding of
// the app — what it is, who uses it, its vocabulary, and environment signals.
// Each profile owns a set of Features (the unit every other part of TestPilot
// references by stable id). Derived/editable data, persisted so it's built once
// and reused; standalone (orgId is a plain column, like TestCaseDescription) so
// it carries no hard FK to Organization — cleanup is handled in session delete.
model AppProfile {
  id    String @id @default(cuid())
  orgId String
  host  String // e.g. "saucedemo.com"

  purpose    String? // one-paragraph: what the app does / its domain
  personas   Json?   // string[] or [{ name, description }] — who uses it
  glossary   Json?   // [{ term, definition }] — the app's domain vocabulary
  envSignals Json?   // { authModel?, spa?, consentVendor?, locales?[] }
  source     String  @default("ai") // crawl | ai | user (strongest wins)
  model      String? // LLM that produced the synthesized fields (auditing)
  // Hash of the inputs (doc + figma + crawl size) the profile was last built from.
  // When the live inputs hash differs, the profile is stale and gets rebuilt.
  sourceHash String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  features Feature[]

  @@unique([orgId, host])
  @@index([orgId])
}

model Feature {
  id        String     @id @default(cuid())
  profileId String
  profile   AppProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  // Denormalized so feature lookups don't always need the profile join.
  orgId String
  host  String

  name             String // e.g. "Checkout", "Product Catalog"
  area             String? // functional area label (legacy `area` maps here)
  journeys         Json?   // critical user journeys: string[] or [{ title, steps[] }]
  expectedOutcomes Json?   // string[] — what success looks like
  negativeOutcomes Json?   // string[] — what should NOT happen (guards/edge cases) (#3)
  intentCoverage   Int?    // 0–100: cached % of expectedOutcomes actually asserted by tests (#1)
  /** Hash of (expectedOutcomes + test titles) at the time intentCoverage was
   *  computed. When the live hash differs, the audit is stale (#5). */
  intentHash       String?
  /** Count of tests mapping to this feature that asserted zero outcomes — i.e.
   *  shallow tests that exist but verify nothing specific (#2). */
  shallowTestCount Int?
  /** Per-outcome traceability — which specific assertion(s) verify each
   *  expectedOutcome (#7). [{ outcome, testTitle?, assertions: string[] }]. */
  outcomeTrace     Json?
  /** Checkable rules that hold across journeys (#4 invariants/properties),
   *  e.g. "cart count = items added", "total = Σ item prices". string[]. */
  invariants       Json?
  criticality      String  @default("normal") // critical | normal | low
  source           String  @default("ai")     // crawl | ai | user
  confidence       String  @default("medium")  // high | medium | low
  // Quarantined features are excluded from the CI gate + critical counts (a
  // known-flaky low-value feature shouldn't block or distort the dashboard).
  quarantined      Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([profileId, name])
  @@index([orgId, host])
}
